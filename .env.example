PORT=9000
JWT_SECRET=change-this-to-a-random-secret
NODE_ENV=production
HOST=0.0.0.0
APP_URL=
ENCRYPTION_KEY=change-this-to-a-random-64-char-hex-string
DEFAULT_ADMIN_PASSWORD=change-this-to-a-secure-password
TRUST_PROXY=true

# PostgreSQL (required)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=bckuser
DB_PASSWORD=bckdbpass
DB_NAME=bckdb

# Optional HTTPS
SSL_CERT_PATH=
SSL_KEY_PATH=
