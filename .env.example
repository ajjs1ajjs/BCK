# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8050

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=backupmanager
DB_USER=backup
DB_PASSWORD=changeme
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
TOKEN_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=720h

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/var/lib/backupmanager/repos

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Notification (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@backupmanager.local

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
