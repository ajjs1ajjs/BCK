FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /backup-api ./cmd/backup-api

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /backup-api /usr/local/bin/backup-api
EXPOSE 8050
ENTRYPOINT ["backup-api"]
