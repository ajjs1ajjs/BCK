{
  "productName": "BCK Backup Manager",
  "version": "1.0.0",
  "identifier": "com.bck.backup-manager",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "BCK Backup Manager",
      "width": 1200,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600
    }],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "notification": { "all": true },
    "fs": { "scope": ["**"] }
  }
}
