{
  "manifest_version": 3,
  "name": "BCK Backup Manager",
  "version": "1.0.0",
  "description": "Quick backup actions and monitoring for BCK Backup Manager",
  "permissions": ["storage", "alarms", "notifications", "bookmarks"],
  "host_permissions": ["http://localhost:8080/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
