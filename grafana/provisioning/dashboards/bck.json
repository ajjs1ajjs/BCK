{
  "__inputs": [],
  "__requires": [{ "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }],
  "annotations": { "list": [] },
  "description": "BCK Backup System — Operational Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Backups",
      "type": "stat",
      "targets": [{ "expr": "sum(bck_backups_total)", "legendFormat": "Total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Active Schedules",
      "type": "stat",
      "targets": [{ "expr": "bck_active_schedules", "legendFormat": "Schedules" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 85 }, { "color": "red", "value": 95 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Disk Free",
      "type": "stat",
      "targets": [{ "expr": "bck_disk_free_bytes", "legendFormat": "Free" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "title": "HTTP Request Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(bck_http_requests_total[5m])", "legendFormat": "req/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Backup Completions by Status",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(bck_backups_total{status=\"completed\"}[5m])", "legendFormat": "Completed" },
        { "expr": "rate(bck_backups_total{status=\"failed\"}[5m])", "legendFormat": "Failed" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HTTP Request Duration (p95)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(bck_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 latency" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "bck_nodejs_heap_size_used_bytes", "legendFormat": "Heap Used" },
        { "expr": "bck_nodejs_heap_size_total_bytes", "legendFormat": "Heap Total" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 8,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Total Backup Data Size",
      "type": "timeseries",
      "targets": [{ "expr": "bck_backup_size_bytes_total", "legendFormat": "{{type}}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["bck", "backup"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BCK Backup System",
  "uid": "bck-main",
  "version": 1
}
